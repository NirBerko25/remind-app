    "expo": "~51.0.0",
    "expo-av": "~14.0.7",
    "expo-linear-gradient": "~13.0.2",
    "expo-location": "~17.0.1",
    "expo-notifications": "~0.28.3",
    "expo-speech": "~12.0.2",
    "expo-status-bar": "~1.12.1",
    "expo-task-manager": "~11.8.2",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-native": "0.74.5",
